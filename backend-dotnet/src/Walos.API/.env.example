# ==============================================
# Walos API - Variables de Entorno (Template)
# Copia este archivo como .env y llena los valores
# ==============================================

# Base de Datos
DB_CONNECTION_STRING=Server=tu-servidor.database.windows.net;Database=tu-base-de-datos;User Id=tu-usuario;Password=tu-password;TrustServerCertificate=true;Encrypt=true;

# JWT
JWT_SECRET=tu-clave-secreta-jwt-de-al-menos-32-caracteres
JWT_EXPIRES_MINUTES=60
JWT_REFRESH_SECRET=tu-clave-secreta-refresh-token
JWT_REFRESH_EXPIRES_DAYS=7

# OpenAI
OPENAI_API_KEY=sk-tu-api-key-de-openai
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=1000
OPENAI_TEMPERATURE=0.7

# CORS (separar origenes por coma, o * para todos)
CORS_ORIGINS=*

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Server
PORT=3000
