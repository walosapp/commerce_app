{
  "AllowedHosts": "*",
  "Port": "3000",

  "ConnectionStrings": {
    "DefaultConnection": "Host=db.<project-ref>.supabase.co;Port=5432;Database=postgres;Username=postgres.<project-ref>;Password=<your-password>;SSL Mode=Require;Trust Server Certificate=true"
  },

  "Jwt": {
    "Secret": "your-super-secret-jwt-key-change-this-in-production-must-be-at-least-32-chars",
    "ExpiresInMinutes": 15,
    "RefreshSecret": "your-super-secret-refresh-key-change-this-in-production",
    "RefreshExpiresInDays": 7
  },

  "OpenAI": {
    "ApiKey": "sk-your-openai-api-key-here",
    "Model": "gpt-4",
    "MaxTokens": 1000,
    "Temperature": "0.7"
  },

  "Cors": {
    "Origins": "*"
  },

  "RateLimiting": {
    "WindowMs": "900000",
    "MaxRequests": "100"
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    }
  }
}
